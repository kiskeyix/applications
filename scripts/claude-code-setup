#!/usr/bin/env ruby
# frozen_string_literal: true

# claude-code-setup — Bootstrap Claude Code environments
# Supports Ubuntu/Debian and RedHat 8.10+
#
# Usage:
#   claude-code-setup install       Install dev tools and configure tmux
#   claude-code-setup remove        Remove bloat packages
#   claude-code-setup setup-claude  Configure ~/.claude (settings, statusline, hooks)
#   claude-code-setup update        Update Claude Code to latest version
#   claude-code-setup all           update + setup-claude + install (full bootstrap)
#   claude-code-setup --help

require 'fileutils'
require 'json'
require 'open3'
require 'optparse'
require 'shellwords'

# ── ANSI color helpers ────────────────────────────────────────────────────────

module C
  def self.ok(s)   = "\e[32m#{s}\e[0m"
  def self.fail(s) = "\e[31m#{s}\e[0m"
  def self.warn(s) = "\e[33m#{s}\e[0m"
  def self.dim(s)  = "\e[2m#{s}\e[0m"
  def self.bold(s) = "\e[1m#{s}\e[0m"
  def self.cyan(s) = "\e[36m#{s}\e[0m"
  def self.tty?    = $stdout.tty?
  def self.strip(s)= s.gsub(/\e\[[0-9;]*m/, '')
end

# ── Step result tracking ──────────────────────────────────────────────────────

class StepError < StandardError; end

class Runner
  COL = 58

  def self.section(title)
    puts "\n#{C.bold(C.cyan("── #{title} ─" + '─' * [0, COL - title.length].max))}"
  end

  # Prints label, runs block, prints Ok/Skip/Fail.
  # Block may return :skip to print "skip" in dim.
  # Raises StepError or any exception to mark Fail.
  # Always returns true/false; never raises.
  def self.step(label, continue_on_fail: true)
    print "  #{label.ljust(COL)}"
    $stdout.flush
    result = yield
    if result == :skip
      puts C.dim('skip')
    else
      puts C.ok('Ok  ')
    end
    true
  rescue StepError => e
    puts C.fail('Fail')
    puts C.dim("    #{e.message}") unless e.message.to_s.empty?
    raise unless continue_on_fail
    false
  rescue => e
    puts C.fail('Fail')
    puts C.dim("    #{e.class}: #{e.message}")
    raise unless continue_on_fail
    false
  end

  # Run a shell command; raises StepError on non-zero exit.
  # When sudo is needed the command is wrapped as `sudo sh -c '...'` so that
  # any VAR=value prefixes (e.g. DEBIAN_FRONTEND=noninteractive) are evaluated
  # by the shell after privilege elevation rather than passed to sudo itself,
  # which rejects env-var assignments in most default sudoers configurations.
  def self.run(cmd, sudo: false, env: {}, input: nil)
    full = if sudo && !running_as_root?
             "sudo sh -c #{cmd.shellescape}"
           else
             cmd
           end
    stdout, stderr, status = Open3.capture3(env, full, stdin_data: input || '')
    raise StepError, (stderr.strip.lines.first(3).join(' | ').strip) unless status.success?
    stdout
  end

  # Non-raising version — returns output or nil on failure.
  def self.try(cmd, sudo: false, env: {})
    run(cmd, sudo: sudo, env: env)
  rescue StepError
    nil
  end

  def self.running_as_root?
    Process.uid == 0
  end

  # True when the script is running as a normal user (not root).
  # Use as the sudo: argument for commands that should only escalate when needed.
  def self.user_sudo?
    !running_as_root?
  end

  def self.command?(name)
    !`which #{name} 2>/dev/null`.strip.empty?
  end

  # Returns :skip if `cmd` is already on PATH; otherwise yields.
  # Removes the boilerplate `if command?(...) then :skip else ... end` in every install method.
  def self.unless_command(name)
    command?(name) ? :skip : yield
  end

  def self.installed_pkg_debian?(pkg)
    system("dpkg -s #{pkg} >/dev/null 2>&1")
  end

  def self.installed_pkg_rhel?(pkg)
    system("rpm -q #{pkg} >/dev/null 2>&1")
  end
end

# ── OS / distro detection ─────────────────────────────────────────────────────

class Platform
  attr_reader :family, :id, :version

  def initialize
    @id, @family, @version = detect
  end

  def debian? = @family == :debian
  def rhel?   = @family == :rhel

  def to_s
    "#{@id} #{@version} (#{@family})"
  end

  def pkg_update_cmd
    if debian?
      'DEBIAN_FRONTEND=noninteractive apt-get -o DPkg::Lock::Timeout=120 update -qq'
    else
      'dnf check-update -q; true'
    end
  end

  def pkg_install_cmd(pkgs, no_recommends: false)
    if debian?
      nr = no_recommends ? '--no-install-recommends ' : ''
      "DEBIAN_FRONTEND=noninteractive apt-get -o DPkg::Lock::Timeout=120 install -y #{nr}#{pkgs.join(' ')}"
    else
      "dnf install -y #{pkgs.join(' ')}"
    end
  end

  def pkg_remove_cmd(pkgs)
    debian? ? "apt-get remove -y --purge #{pkgs.join(' ')}" \
            : "dnf remove -y #{pkgs.join(' ')}"
  end

  def pkg_autoremove_cmd
    debian? ? 'apt-get autoremove -y --purge' : 'dnf autoremove -y'
  end

  def pkg_installed?(pkg)
    debian? ? Runner.installed_pkg_debian?(pkg) : Runner.installed_pkg_rhel?(pkg)
  end

  def arch
    @arch ||= `uname -m`.strip
  end

  def epel_needed? = rhel?

  private

  def detect
    return [:unknown, :unknown, ''] unless File.exist?('/etc/os-release')

    info = File.read('/etc/os-release').scan(/^(\w+)=(.+)$/).to_h do |k, v|
      [k.downcase, v.delete('"\'')]
    end

    id      = (info['id'] || 'unknown').downcase
    like    = (info['id_like'] || '').downcase
    version = info['version_id'] || ''

    family = if %w[ubuntu debian].include?(id) || like.include?('debian')
               :debian
             elsif %w[rhel centos fedora rocky almalinux].include?(id) || like.match?(/rhel|centos|fedora/)
               :rhel
             else
               :unknown
             end

    [id, family, version]
  end
end

