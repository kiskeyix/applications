        ]
      }
    ]
  }
}.freeze

# ── Hook scripts ──────────────────────────────────────────────────────────────

# SessionStart hook: prints date, git context, and memory reminder into the
# conversation as a <system-reminder> block so Claude sees it immediately.
SESSION_START_HOOK = <<~'SH'
  #!/usr/bin/env bash
  # ~/.claude/hooks/session-start.sh
  # Runs at the start of every Claude Code session.
  # Output is injected into the conversation as a system-reminder.

  set -euo pipefail

  DATE=$(date '+%A %Y-%m-%d %H:%M %Z')
  HOST=$(hostname -s 2>/dev/null || echo "$HOSTNAME")
  USER_NAME=${USER:-$(id -un)}

  echo "=== SESSION START ==="
  echo "Time : $DATE"
  echo "Host : $HOST  User: $USER_NAME"

  # Git context if inside a repo
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD)
    STATUS=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
    REMOTE=$(git remote get-url origin 2>/dev/null | sed 's|.*[:/]\([^/]*/[^/]*\)$|\1|' || echo "")
    echo "Git  : branch=$BRANCH  dirty=$STATUS files${REMOTE:+  remote=$REMOTE}"
  fi

  # Memory reminder (if .remember/ exists in home)
  REMEMBER_DIR="$HOME/.remember"
  if [[ -d "$REMEMBER_DIR" ]]; then
    NOW_FILE="$REMEMBER_DIR/now.md"
    if [[ -f "$NOW_FILE" ]]; then
      echo ""
      echo "--- now.md (recent context) ---"
      tail -20 "$NOW_FILE"
    fi
    TODAY=$(date '+%Y-%m-%d')
    TODAY_FILE="$REMEMBER_DIR/today-${TODAY}.md"
    if [[ -f "$TODAY_FILE" ]]; then
      echo ""
      echo "--- today's log ---"
      tail -30 "$TODAY_FILE"
    fi
  fi

  echo "=== END SESSION START ==="
SH

# Stop hook: desktop notification when Claude finishes a response.
# Works on Linux (notify-send), macOS (osascript), and silently skips
# if neither is available (e.g. headless servers).
NOTIFY_STOP_HOOK = <<~'SH'
  #!/usr/bin/env bash
  # ~/.claude/hooks/notify-stop.sh
  # Fires on every Claude "Stop" event (when Claude finishes responding).
  # Sends a desktop notification so you know it's done without watching the terminal.

  # Parse optional JSON input for context (Claude may pass stop reason, etc.)
  REASON=""
  if command -v jq >/dev/null 2>&1 && [[ -p /dev/stdin ]]; then
    INPUT=$(cat)
    REASON=$(echo "$INPUT" | jq -r '.stop_reason // empty' 2>/dev/null || true)
  fi

  TITLE="Claude Code"
  BODY="${REASON:-Claude finished}"

  if command -v notify-send >/dev/null 2>&1; then
    # Linux / GNOME / libnotify
    notify-send --app-name "Claude Code" \
                --icon utilities-terminal \
                --expire-time 4000 \
                "$TITLE" "$BODY" 2>/dev/null || true

  elif command -v osascript >/dev/null 2>&1; then
    # macOS fallback
    osascript -e "display notification \"$BODY\" with title \"$TITLE\"" 2>/dev/null || true

  elif command -v terminal-notifier >/dev/null 2>&1; then
    terminal-notifier -title "$TITLE" -message "$BODY" 2>/dev/null || true
  fi

  # Also ring the terminal bell so tmux can surface it in the status bar
  printf '\a'

  exit 0
SH

STATUSLINE_RB = <<~'RUBY'
  #!/usr/bin/env ruby
  # ~/.claude/statusline.rb — Claude Code status bar
  # Shows rate-limit usage (5h / 7d) and context window consumption.
  # Input: JSON on stdin from Claude Code. Output: one line to stdout.

  require 'json'
  require 'time'

  input = JSON.parse($stdin.read) rescue {}

  def bar(pct, width: 8)
    pct   = pct.to_f.clamp(0, 100)
    filled = (pct / 100.0 * width).round
    '█' * filled + '░' * (width - filled)
  end

  def resets_in(iso)
    t = Time.parse(iso) rescue nil
    return nil unless t
    secs = (t - Time.now).to_i
    return '0m' if secs <= 0
    secs < 3600 ? "#{secs / 60}m" : "#{secs / 3600}h#{(secs % 3600) / 60}m"
  end

  def pct_str(pct) = format('%5.1f%%', pct.to_f)

  parts = []

  if (rl = input['rate_limits'])
    fh = rl['five_hour']
    sd = rl['seven_day']
    if fh && (pct = fh['used_percentage'])
      reset = fh['resets_at'] ? " ↺#{resets_in(fh['resets_at'])}" : ''
      parts << "5h #{bar(pct)} #{pct_str(pct)}#{reset}"
    end
    if sd && (pct = sd['used_percentage'])
      reset = sd['resets_at'] ? " ↺#{resets_in(sd['resets_at'])}" : ''
      parts << "7d #{bar(pct)} #{pct_str(pct)}#{reset}"
    end
  end

  ctx_pct = input.dig('context_window', 'used_percentage') ||
            input.dig('current_usage',  'used_percentage')
  parts << "ctx #{bar(ctx_pct)} #{pct_str(ctx_pct)}" if ctx_pct

  effort  = input.dig('effort', 'level')
  thinking = input.dig('thinking', 'enabled')
  meta = [effort, (thinking ? 'think' : nil)].compact
  parts << meta.join(' ') unless meta.empty?

  puts parts.join('  │  ')
RUBY

TMUX_CONF = <<~'TMUX'
  # ═══════════════════════════════════════════════════════════════════════════
  # TMUX CONFIG — Optimised for Claude Code
  # ═══════════════════════════════════════════════════════════════════════════

  # ── TERMINAL & COLOR ─────────────────────────────────────────────────────────
  set -g default-terminal "tmux-256color"
  set -ga terminal-overrides ",*:Tc"
  set -ga terminal-overrides ",*:RGB"
  set -ga terminal-overrides ",*:Smulx=\E[4::%p1%dm"
  set -ga terminal-overrides ",*:Setulc=\E[58::2::%p1%{65536}%/%d::%p1%{256}%/%{255}%&%d::%p1%{255}%&%dm"
  set -g update-environment "COLORTERM"
  set-environment -g COLORTERM truecolor
  set-option -g set-titles on
  set-option -g set-titles-string '#T'

  # ── EXTENDED KEYS & IMAGE SUPPORT ────────────────────────────────────────────
  # Extended key encoding (CSI u) — required for Claude Code Alt-key shortcuts
  set -s extended-keys on
  set -as terminal-features 'xterm*:extkeys'
  # Sixel inline images (tmux 3.4+, requires tmux built with --enable-sixel)
  set -as terminal-features 'xterm*:sixel'

  # ── OSC PASSTHROUGH ───────────────────────────────────────────────────────────
  # Critical for Claude Code: OSC notifications, progress bar, /copy, hyperlinks
  set -g allow-passthrough on
  set -g set-clipboard on

  # ── FOCUS & ESCAPE ────────────────────────────────────────────────────────────
  # focus-events off: prevents ^[[I/^[[O sequences leaking into interactive prompts
  # when switching iTerm2 tabs/windows while a pane is waiting for input (read, etc.)
  set -g focus-events off
  set -sg escape-time 10

  # ── MOUSE & HISTORY ──────────────────────────────────────────────────────────
  # Mouse off — mouse events confuse tmux -CC / iTerm2 integration
  # set -g mouse on
  set -g history-limit 50000

  # ── WINDOW / PANE NUMBERING ──────────────────────────────────────────────────
  set -g base-index 1
  setw -g pane-base-index 1
  set -g renumber-windows on

  # ── BELL — surfaces Claude's completion bell in the status bar ────────────────
  set -g bell-action any
  set -g visual-bell on
  set -g activity-action other

  # ── KEY BINDINGS ─────────────────────────────────────────────────────────────
  # Ctrl-a prefix (leaves Ctrl-b free for Claude's "background task" shortcut)
  unbind C-b
  set -g prefix C-a
  bind C-a send-prefix

  bind r source-file ~/.tmux.conf \; display "Config reloaded"

  bind | split-window -h -c "#{pane_current_path}"
  bind - split-window -v -c "#{pane_current_path}"
  bind c new-window -c "#{pane_current_path}"

  bind h select-pane -L
  bind j select-pane -D
  bind k select-pane -U
  bind l select-pane -R

  bind -r H resize-pane -L 5
  bind -r J resize-pane -D 5
  bind -r K resize-pane -U 5
  bind -r L resize-pane -R 5

  # Claude layout: main pane + narrow log pane on the right
  bind C-c split-window -h -p 30 -c "#{pane_current_path}" \; select-pane -L

  # ── STATUS BAR ───────────────────────────────────────────────────────────────
  set -g status on
  set -g status-interval 5
  set -g status-position bottom
  set -g status-style "bg=#1e1e2e,fg=#cdd6f4"
  set -g window-status-style "bg=#313244,fg=#cdd6f4"
  set -g window-status-current-style "bg=#89b4fa,fg=#1e1e2e,bold"
  set -g pane-border-style "fg=#313244"
  set -g pane-active-border-style "fg=#89b4fa"
  set -g message-style "bg=#f38ba8,fg=#1e1e2e,bold"
  set -g status-left-length 30
  set -g status-left "#[bg=#89b4fa,fg=#1e1e2e,bold] #S #[default] "
  set -g status-right-length 60
  set -g status-right "#[fg=#a6adc8]#H  #[fg=#cdd6f4]%Y-%m-%d  %H:%M"
  set -g window-status-format " #I:#W#{?window_bell_flag,!,} "
  set -g window-status-current-format " #I:#W#{?window_bell_flag,!,} "

  # ── COPY MODE ────────────────────────────────────────────────────────────────
  setw -g mode-keys vi
  bind Enter copy-mode
  bind -T copy-mode-vi v send -X begin-selection
  bind -T copy-mode-vi y send -X copy-pipe-and-cancel "pbcopy 2>/dev/null || xclip -sel clip 2>/dev/null || wl-copy 2>/dev/null || true"
  bind -T copy-mode-vi MouseDragEnd1Pane send -X copy-pipe-and-cancel "pbcopy 2>/dev/null || xclip -sel clip 2>/dev/null || wl-copy 2>/dev/null || true"
TMUX

# ── Action classes ────────────────────────────────────────────────────────────

class ClaudeSetup
  def initialize(platform)
    @platform = platform
  end

  def run
    Runner.section('~/.claude configuration')

    Runner.step('Create ~/.claude and hooks/ directories') do
      FileUtils.mkdir_p(CLAUDE_DIR)
      FileUtils.mkdir_p(File.join(CLAUDE_DIR, 'hooks'))
    end

    Runner.step('Write ~/.claude/settings.json') do
      path = File.join(CLAUDE_DIR, 'settings.json')
      if File.exist?(path)
        existing = JSON.parse(File.read(path)) rescue {}
        # Deep-merge: existing user keys win; we only fill in missing ones
        merged = deep_merge(CLAUDE_SETTINGS, existing)
        File.write(path, JSON.pretty_generate(merged))
      else
        File.write(path, JSON.pretty_generate(CLAUDE_SETTINGS))
      end
    end

    Runner.step('Write ~/.claude/statusline.rb') do
      path = File.join(CLAUDE_DIR, 'statusline.rb')
      File.write(path, STATUSLINE_RB)
      File.chmod(0o755, path)
    end

    Runner.section('~/.claude/hooks')

    Runner.step('Write session-start.sh (date / git / memory reminder)') do
      write_hook('session-start.sh', SESSION_START_HOOK)
    end

    Runner.step('Write notify-stop.sh (desktop notification on Stop)') do
      write_hook('notify-stop.sh', NOTIFY_STOP_HOOK)
    end

    setup_tmux
  end

  private

  def write_hook(filename, content)
    path = File.join(CLAUDE_DIR, 'hooks', filename)
    File.write(path, content)
    File.chmod(0o755, path)
  end

  def deep_merge(base, override)
    base.merge(override) do |_key, base_val, override_val|
      if base_val.is_a?(Hash) && override_val.is_a?(Hash)
        deep_merge(base_val, override_val)
      else
        override_val
      end
    end
  end

  def setup_tmux
    Runner.section('tmux configuration')

    conf = File.join(Dir.home, '.tmux.conf')

    Runner.step('Back up existing ~/.tmux.conf') do
      if File.exist?(conf)
        backup = "#{conf}.bak.#{Time.now.strftime('%Y%m%d%H%M%S')}"
        FileUtils.cp(conf, backup)
      else
        :skip
      end
    end

    Runner.step('Write Claude-optimised ~/.tmux.conf') do
      File.write(conf, TMUX_CONF)
    end

    Runner.step('Install tpm (tmux plugin manager)') do
      tpm = File.join(Dir.home, '.tmux/plugins/tpm')
      if Dir.exist?(tpm)
        Runner.try("git -C #{tpm} pull --ff-only 2>/dev/null")
        :skip
      else
        Runner.run("git clone https://github.com/tmux-plugins/tpm #{tpm}")
      end
    end

    Runner.step('Install tmux plugins via tpm') do
      tpm_install = File.join(Dir.home, '.tmux/plugins/tpm/bin/install_plugins')
      if File.exist?(tpm_install)
        Runner.try(tpm_install)
      end
      :skip
    end

    Runner.step('Reload live tmux server') do
      if system('tmux info >/dev/null 2>&1')
        Runner.run("tmux source-file #{conf}")
      else
        :skip
      end
    end
  end
end

LOCAL_BIN = File.join(Dir.home, '.local', 'bin').freeze

# Shared logic for PATH setup and Claude install/update used by both
# Updater and Installer.
module ClaudeInstaller
  def setup_local_bin
    Runner.step('Ensure ~/.local/bin exists') { FileUtils.mkdir_p(LOCAL_BIN) }
    Runner.step('Add ~/.local/bin to PATH in shell profile') { ensure_local_bin_in_path }
  end

  def install_or_update_claude
    Runner.step('Install / update Claude Code → ~/.local/bin') do
      if Runner.command?('claude')
        Runner.run('claude update')
      elsif Runner.command?('npm')
        Runner.run("npm install -g --prefix #{Dir.home}/.local @anthropic-ai/claude-code")
      else
        raise StepError, 'npm not found — run claude-code-setup install first'
      end
    end
  end

  def ensure_local_bin_in_path
    # Prefer ~/.bash_profile; fall back to ~/.profile (POSIX sh).
    profile = [
      File.join(Dir.home, '.bash_profile'),
      File.join(Dir.home, '.profile')
    ].find { |f| File.exist?(f) } || File.join(Dir.home, '.bash_profile')

    snippet = <<~SH
      # Added by claude-code-setup — keep ~/.local/bin first on PATH
      export PATH="$HOME/.local/bin:$PATH"
    SH

    content = File.exist?(profile) ? File.read(profile) : ''
    if content.include?('/.local/bin')
      return :skip
    end

    File.write(profile, content.end_with?("\n") ? content + "\n" + snippet : content + "\n\n" + snippet)
    profile  # return value just for logging; truthy = Ok
  end
end

class Updater
  include ClaudeInstaller

  def initialize(platform)
    @platform = platform
  end

  def run
    Runner.section('Claude Code update')
    setup_local_bin
    install_or_update_claude
  end
end

class Installer
  include ClaudeInstaller

  def initialize(platform)
    @platform = platform
  end

  def run
    if @platform.unknown?
      puts C.warn("\n  Unsupported platform — skipping package manager steps.")
      puts C.dim("  mise, gems, npm, and Claude Code installs will still be attempted.\n")
    end

    Runner.section('Package index update')
    Runner.step("#{@platform.macos? ? 'brew' : 'apt-get / dnf'} update") do
      next :skip if @platform.unknown?
      Runner.run(@platform.pkg_update_cmd, sudo: @platform.pkg_sudo?)
    end

    if @platform.epel_needed?
      Runner.section('EPEL repository')
      install_epel
    end

    INSTALL_GROUPS.each do |key, group|
      pkgs = group[@platform.family] || []
      next if pkgs.empty?

      Runner.section("#{group[:desc]}")

      to_install = pkgs.reject { |p| @platform.pkg_installed?(p) }
      if to_install.empty?
        Runner.step("All #{group[:desc].downcase} packages present") { :skip }
      else
        Runner.step("Install #{to_install.length} package(s)") do
          cmd = @platform.pkg_install_cmd(to_install, no_recommends: @platform.debian?)
          Runner.run(cmd, sudo: @platform.pkg_sudo?)
        end
      end
    end

    Runner.section('Post-install: GitHub CLI')
    install_gh

    Runner.section('Post-install: Docker Compose v2 plugin')
    install_docker_compose

    Runner.section('Post-install: kubectl')
    install_kubectl

    Runner.section('Post-install: helm')
    install_helm

    Runner.section('Post-install: mise (version manager)')
    install_mise
    install_mise_ruby

    Runner.section('Post-install: Ruby gems')
    install_gems

    Runner.section('Post-install: npm globals')
    install_npm_globals

    Runner.section('Post-install: pipx tools')
    install_pipx_tools

    Runner.section('Post-install: fd symlink')
    install_fd_symlink

    Runner.section('Post-install: Claude Code')
    install_claude

    Runner.section('Cleanup')
    Runner.step('autoremove / clean') do
      next :skip if @platform.unknown?
      Runner.run(@platform.pkg_autoremove_cmd, sudo: @platform.pkg_sudo?)
      Runner.run('apt-get clean', sudo: true) if @platform.debian?
    end
  end

  private

  def install_epel
    Runner.step('Enable EPEL and PowerTools/CRB') do
      if Runner.try('rpm -q epel-release', sudo: false)
        :skip
      else
        Runner.run('dnf install -y epel-release', sudo: true)
        # Try enabling CodeReady Builder (RHEL 8) or CRB (Rocky/Alma)
        Runner.try('subscription-manager repos --enable codeready-builder-for-rhel-8-x86_64-rpms', sudo: true)
        Runner.try('dnf config-manager --set-enabled powertools', sudo: true)
        Runner.try('dnf config-manager --set-enabled crb', sudo: true)
      end
    end
  end

  def install_gh
    Runner.step('gh → ~/.local/bin (or Homebrew)') do
      Runner.unless_command('gh') do
        if @platform.macos?
          Runner.run('brew install gh')
        elsif @platform.linux?
          arch = @platform.dl_arch
          Runner.run(
            "bash -c \"" \
            "VER=\\$(curl -fsSL https://api.github.com/repos/cli/cli/releases/latest " \
            "| grep '\"tag_name\"' | cut -d'\"' -f4 | sed 's/^v//') && " \
            "curl -fsSL https://github.com/cli/cli/releases/download/v\\${VER}/" \
            "gh_\\${VER}_linux_#{arch}.tar.gz " \
            "| tar -xzf - --strip-components=2 -C #{LOCAL_BIN} " \
            "gh_\\${VER}_linux_#{arch}/bin/gh\""
          )
        else
          :skip
        end
      end
    end
  end

  def install_docker_compose
    Runner.step('Docker Compose v2 → ~/.docker/cli-plugins (or Homebrew)') do
      if system('docker compose version >/dev/null 2>&1')
        :skip
      elsif @platform.macos?
        Runner.run('brew install docker-compose')
      elsif @platform.linux?
        docker_plugins = File.join(Dir.home, '.docker', 'cli-plugins')
        FileUtils.mkdir_p(docker_plugins)
        dest = File.join(docker_plugins, 'docker-compose')
        Runner.run(
          "curl -fsSL https://github.com/docker/compose/releases/latest/download/" \
          "docker-compose-linux-#{@platform.arch} -o #{dest}"
        )
        File.chmod(0o755, dest)
      else
        :skip
      end
    end
  end

  def install_kubectl
    Runner.step('kubectl → ~/.local/bin (or Homebrew)') do
      Runner.unless_command('kubectl') do
        if @platform.macos?
          Runner.run('brew install kubectl')
        elsif @platform.linux?
          arch = @platform.dl_arch
          Runner.run(
            "bash -c \"" \
            "VER=\\$(curl -fsSL https://dl.k8s.io/release/stable.txt) && " \
            "curl -fsSLo #{LOCAL_BIN}/kubectl " \
            "https://dl.k8s.io/release/\\${VER}/bin/linux/#{arch}/kubectl && " \
            "chmod +x #{LOCAL_BIN}/kubectl\""
          )
        else
          :skip
        end
      end
    end
  end

  def install_helm
    Runner.step('helm → ~/.local/bin (or Homebrew)') do
      Runner.unless_command('helm') do
        if @platform.macos?
          Runner.run('brew install helm')
        elsif @platform.linux?
          arch = @platform.dl_arch
          Runner.run(
            "bash -c \"curl -fsSL https://get.helm.sh/helm-latest-linux-#{arch}.tar.gz " \
            "| tar -xzf - --strip-components=1 -C #{LOCAL_BIN} linux-#{arch}/helm\""
          )
        else
          :skip
        end
      end
    end
  end

  def install_mise
    Runner.step('mise → ~/.local/bin (or Homebrew)') do
      if Runner.command?('mise')
        Runner.try("mise self-update 2>/dev/null || true")
        :skip
      elsif @platform.macos?
        Runner.run('brew install mise')
        ensure_mise_in_bashrc
      else
        Runner.run('curl -fsSL https://mise.run | sh')
        ensure_mise_in_bashrc
      end
    end
  end

  def install_mise_ruby
    # Resolve actual mise binary regardless of install method
    mise = `which mise 2>/dev/null`.strip
    mise = File.join(LOCAL_BIN, 'mise') if mise.empty?
    env  = { 'MISE_YES' => '1' }

    Runner.step('mise: install ruby@latest (may take a minute)') do
      unless File.exist?(mise) || Runner.command?('mise')
        :skip
      else
        current   = Runner.try("#{mise} latest ruby 2>/dev/null")&.strip
        installed = Runner.try("#{mise} list ruby 2>/dev/null")&.include?(current.to_s)
        if installed
          :skip
        else
          Runner.run("#{mise} install --quiet ruby@latest", env: env)
        end
      end
    end

    Runner.step('mise: set ruby@latest as global default') do
      unless File.exist?(mise) || Runner.command?('mise')
        :skip
      else
        Runner.run("#{mise} use --global ruby@latest", env: env)
      end
    end
  end

  def install_gems
    gems = %w[rubocop pry rake solargraph amazing_print tmuxinator]
    gem_home = File.join(Dir.home, '.local', 'share', 'gem')
    # Use mise-managed ruby if available, otherwise fall through to system gem
    mise = `which mise 2>/dev/null`.strip
    gem_cmd = mise.empty? ? 'gem' : "#{mise} exec ruby -- gem"
    Runner.step("Ruby gems → ~/.local/share/gem: #{gems.join(', ')}") do
      Runner.run(
        "#{gem_cmd} install --no-document " \
        "--install-dir #{gem_home} " \
        "--bindir #{LOCAL_BIN} " \
        "#{gems.join(' ')}"
      )
    end
  end

  def install_npm_globals
    return unless Runner.command?('npm')

    pkgs = %w[typescript ts-node prettier eslint pnpm yarn nodemon serve tldr]
    Runner.step("npm globals → ~/.local: #{pkgs.join(', ')}") do
      Runner.run("npm install -g --prefix #{Dir.home}/.local --quiet #{pkgs.join(' ')}")
    end
  end

  def install_pipx_tools
    return unless Runner.command?('pipx')

    tools = %w[httpie glances yt-dlp poetry ruff]
    tools.each do |tool|
      Runner.step("pipx: #{tool}") do
        if Runner.try("pipx list 2>/dev/null | grep #{tool}")
          :skip
        else
          Runner.try("pipx install #{tool} 2>/dev/null")
          :skip  # non-fatal
        end
      end
    end
  end

  def install_fd_symlink
    Runner.step("'fd' symlink → ~/.local/bin") do
      # Debian installs fd as fdfind; macOS and RHEL use fd directly
      if @platform.debian? && Runner.command?('fdfind') && !Runner.command?('fd')
        FileUtils.ln_sf(`which fdfind`.strip, File.join(LOCAL_BIN, 'fd'))
      else
        :skip
      end
    end
  end

  def install_claude
    setup_local_bin
    install_or_update_claude
  end

  def ensure_mise_in_bashrc
    rc = File.join(Dir.home, '.bashrc')
    content = File.exist?(rc) ? File.read(rc) : ''
    return :skip if content.include?('mise activate')

    snippet = <<~SH

      # mise — polyglot version manager (added by claude-code-setup)
      [[ -x "$HOME/.local/bin/mise" ]] && eval "$($HOME/.local/bin/mise activate bash)"
    SH
    File.write(rc, content + snippet)
  end
end

class Remover
  def initialize(platform)
    @platform = platform
  end

  def run
    if @platform.macos?
      puts C.warn("\n  remove is a no-op on macOS — use `brew uninstall` manually.")
      return
    end

    if @platform.unknown?
      puts C.warn("\n  Unsupported platform — remove is not available.")
      return
    end

    REMOVE_GROUPS.each do |_key, group|
      pkgs = group[@platform.family] || []
      next if pkgs.empty?

      Runner.section("Remove: #{group[:desc]}")

      installed = pkgs.select { |p| @platform.pkg_installed?(p) }
      if installed.empty?
        Runner.step("No #{group[:desc].downcase} packages found") { :skip }
      else
        Runner.step("Remove #{installed.length} package(s): #{installed.join(', ')}") do
          Runner.run(@platform.pkg_remove_cmd(installed), sudo: @platform.pkg_sudo?)
        end
      end
    end

    Runner.section('Autoremove orphaned dependencies')
    Runner.step('autoremove') do
      Runner.run(@platform.pkg_autoremove_cmd, sudo: @platform.pkg_sudo?)
    end
  end
end

# ── CLI entry point ───────────────────────────────────────────────────────────

def usage
  puts <<~USAGE
    #{C.bold('claude-code-setup')} — Bootstrap Claude Code environments

    #{C.bold('Usage:')}
      claude-code-setup <command> [options]

    #{C.bold('Commands:')}
      #{C.cyan('install')}        Install dev tools and Claude Code
      #{C.cyan('remove')}         Remove bloat packages (Linux only)
      #{C.cyan('setup-claude')}   Configure ~/.claude (settings, statusline, tmux)
      #{C.cyan('update')}         Update Claude Code (requires npm from install)
      #{C.cyan('all')}            Full bootstrap: setup-claude + install

    #{C.bold('Options:')}
      --help, -h      Show this help
      --version, -v   Show version

    #{C.bold('Supported platforms:')}
      macOS 13+ (Homebrew — no sudo required)
      Ubuntu / Debian (apt)
      Red Hat 8.10 / Rocky / AlmaLinux (dnf + EPEL)
  USAGE
end

VERSION = '1.1.0'

ARGV.push('--help') if ARGV.empty?

command = nil
OptionParser.new do |opts|
  opts.on('-h', '--help')    { usage; exit 0 }
  opts.on('-v', '--version') { puts VERSION; exit 0 }
end.order!(ARGV)

command = ARGV.shift&.downcase

unless %w[install remove setup-claude update all].include?(command)
  usage
  exit 1
end

platform = Platform.new

puts C.bold("\nClaude Code Setup #{VERSION}")
puts C.dim("Platform: #{platform}")
puts C.dim("Running as: #{Runner.running_as_root? ? 'root' : ENV['USER']} (uid=#{Process.uid})")

case command
when 'update'
  Updater.new(platform).run

when 'setup-claude'
  ClaudeSetup.new(platform).run

when 'install'
  Installer.new(platform).run

when 'remove'
  Remover.new(platform).run

when 'all'
  ClaudeSetup.new(platform).run
  Installer.new(platform).run
end

puts "\n#{C.bold('Done.')}\n"
