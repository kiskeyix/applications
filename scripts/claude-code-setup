# ─────────────────────────────────────────────────────────────────────────────
#
# OVERVIEW
#
#   Single-file Ruby script that bootstraps a Claude Code development
#   environment on macOS (Homebrew), Ubuntu/Debian (apt), and Red Hat
#   8.10+ / Rocky / AlmaLinux (dnf + EPEL).
#   Safe to run multiple times — every step is idempotent.
#
# HOW IT WORKS
#
#   Each action is wrapped in a Runner.step block that prints a labelled
#   line ending in Ok (green), skip (dim), or Fail (red).  Steps that find
#   their target already in the desired state return :skip rather than
#   re-running.  Failures are logged and execution continues by default so
#   a single broken package never aborts the whole run.
#
#   No step writes to a system path unless it has to (Linux package manager
#   operations go through sudo; Homebrew and everything else lands under the
#   calling user's home directory):
#
#     ~/.local/bin          binaries: mise, helm, kubectl, gh, docker-compose,
#                           Claude Code, fd symlink, gem executables, npm bins
#     ~/.local/share/gem    Ruby gems installed via `gem install`
#     ~/.local/share/npm    npm global packages (--prefix ~/.local)
#     ~/.docker/cli-plugins Docker Compose v2 plugin (Linux)
#     ~/.mise               mise data dir (versions, shims, plugins)
#     ~/.claude             settings.json, statusline.rb, hooks/
#     ~/.tmux.conf          Claude-optimised tmux configuration
#     ~/.bashrc             mise activation line appended if absent
#     ~/.bash_profile /
#       ~/.profile          ~/.local/bin PATH export appended if absent
#
#   macOS: all package operations use `brew` (never sudo).
#   Linux: system package installation (apt-get / dnf) always runs under sudo.
#   npm, gem, curl-based binary downloads, and mise all run as the
#   current user with no privilege escalation on all platforms.
#
# COMMANDS
#
#   install       Update package index, install all tool groups (terminal,
#                 build, languages, containers, editors, …), post-install
#                 binaries (mise, Ruby via mise, gems, npm globals, gh,
#                 helm, kubectl, docker-compose), and Claude Code.
#   remove        Purge bloat packages (LibreOffice, games, printer drivers,
#                 indic fonts, cloud-init, screen-reader stack).
#                 No-op on macOS (use `brew uninstall` manually).
#   setup-claude  Write ~/.claude/settings.json, statusline.rb, session-
#                 start and notify-stop hooks, and ~/.tmux.conf.
#   update        Ensure ~/.local/bin exists, then install or update
#                 Claude Code via `claude update` (or npm if not yet present).
#   all           setup-claude + install (full first-time bootstrap).
#
# IDEMPOTENCY GUARANTEES
#
#   • Packages: skipped if already installed (dpkg -s / rpm -q / brew list).
#   • Binaries: skipped if the command is already on PATH (`which`).
#   • mise Ruby: skipped if the latest version is already the global default.
#   • npm globals: re-running is a no-op (npm skips already-current pkgs).
#   • ~/.claude files: settings.json is deep-merged so existing user keys
#     are preserved; hook scripts and statusline are overwritten to stay
#     current.
#   • ~/.tmux.conf: backed up with a timestamp before every write.
#   • ~/.bashrc / profile snippets: checked for a marker string before
#     appending; never duplicated.
#
# USAGE
#
#   claude-code-setup install       Install dev tools and Claude Code
#   claude-code-setup remove        Remove bloat packages (Linux only)
#   claude-code-setup setup-claude  Configure ~/.claude (settings, statusline, hooks)
#   claude-code-setup update        Update Claude Code to latest version
#   claude-code-setup all           Full bootstrap: setup-claude + install
#   claude-code-setup --help

require 'fileutils'
require 'json'
require 'open3'
require 'optparse'
require 'shellwords'

# ── ANSI color helpers ────────────────────────────────────────────────────────

module C
  def self.ok(s)   = "\e[32m#{s}\e[0m"
  def self.fail(s) = "\e[31m#{s}\e[0m"
  def self.warn(s) = "\e[33m#{s}\e[0m"
  def self.dim(s)  = "\e[2m#{s}\e[0m"
  def self.bold(s) = "\e[1m#{s}\e[0m"
  def self.cyan(s) = "\e[36m#{s}\e[0m"
  def self.tty?    = $stdout.tty?
  def self.strip(s)= s.gsub(/\e\[[0-9;]*m/, '')
end

# ── Step result tracking ──────────────────────────────────────────────────────

class StepError < StandardError; end

class Runner
  COL = 58

  def self.section(title)
    puts "\n#{C.bold(C.cyan("── #{title} ─" + '─' * [0, COL - title.length].max))}"
  end

  # Prints label, runs block, prints Ok/Skip/Fail.
  # Block may return :skip to print "skip" in dim.
  # Raises StepError or any exception to mark Fail.
  # Always returns true/false; never raises.
  def self.step(label, continue_on_fail: true)
    print "  #{label.ljust(COL)}"
    $stdout.flush
    result = yield
    if result == :skip
      puts C.dim('skip')
    else
      puts C.ok('Ok  ')
    end
    true
  rescue StepError => e
    puts C.fail('Fail')
    puts C.dim("    #{e.message}") unless e.message.to_s.empty?
    raise unless continue_on_fail
    false
  rescue => e
    puts C.fail('Fail')
    puts C.dim("    #{e.class}: #{e.message}")
    raise unless continue_on_fail
    false
  end

  # Run a shell command; raises StepError on non-zero exit.
  # When sudo is needed the command is wrapped as `sudo sh -c '...'` so that
  # any VAR=value prefixes (e.g. DEBIAN_FRONTEND=noninteractive) are evaluated
  # by the shell after privilege elevation rather than passed to sudo itself,
  # which rejects env-var assignments in most default sudoers configurations.
  def self.run(cmd, sudo: false, env: {}, input: nil)
    full = if sudo && !running_as_root?
             "sudo sh -c #{cmd.shellescape}"
           else
             cmd
           end
    stdout, stderr, status = Open3.capture3(env, full, stdin_data: input || '')
    raise StepError, (stderr.strip.lines.first(3).join(' | ').strip) unless status.success?
    stdout
  end

  # Non-raising version — returns output or nil on failure.
  def self.try(cmd, sudo: false, env: {})
    run(cmd, sudo: sudo, env: env)
  rescue StepError
    nil
  end

  def self.running_as_root?
    Process.uid == 0
  end

  # True when the script is running as a normal user (not root).
  # Use as the sudo: argument for commands that should only escalate when needed.
  def self.user_sudo?
    !running_as_root?
  end

  def self.command?(name)
    !`which #{name} 2>/dev/null`.strip.empty?
  end

  # Returns :skip if `cmd` is already on PATH; otherwise yields.
  # Removes the boilerplate `if command?(...) then :skip else ... end` in every install method.
  def self.unless_command(name)
    command?(name) ? :skip : yield
  end

  def self.installed_pkg_debian?(pkg)
    system("dpkg -s #{pkg} >/dev/null 2>&1")
  end

  def self.installed_pkg_rhel?(pkg)
    system("rpm -q #{pkg} >/dev/null 2>&1")
  end

  def self.installed_pkg_brew?(pkg)
    system("brew list --formula #{pkg} >/dev/null 2>&1") ||
      system("brew list --cask #{pkg} >/dev/null 2>&1")
  end
end

# ── OS / distro detection ─────────────────────────────────────────────────────

class Platform
  attr_reader :family, :id, :version

  def initialize
    @id, @family, @version = detect
  end

  def macos?   = @family == :macos
  def debian?  = @family == :debian
  def rhel?    = @family == :rhel
  def unknown? = @family == :unknown
  def linux?   = debian? || rhel?

  # Homebrew must never run under sudo; Linux package managers require it.
  def pkg_sudo?
    !macos? && !Runner.running_as_root?
  end

  def to_s
    "#{@id} #{@version} (#{@family})"
  end

  def pkg_update_cmd
    case @family
    when :macos  then 'brew update'
    when :debian then 'DEBIAN_FRONTEND=noninteractive apt-get -o DPkg::Lock::Timeout=120 update -qq'
    else              'dnf check-update -q; true'
    end
  end

  def pkg_install_cmd(pkgs, no_recommends: false)
    case @family
    when :macos  then "brew install #{pkgs.join(' ')}"
    when :debian
      nr = no_recommends ? '--no-install-recommends ' : ''
      "DEBIAN_FRONTEND=noninteractive apt-get -o DPkg::Lock::Timeout=120 install -y #{nr}#{pkgs.join(' ')}"
    else
      "dnf install -y #{pkgs.join(' ')}"
    end
  end

  def pkg_remove_cmd(pkgs)
    case @family
    when :macos  then "brew uninstall #{pkgs.join(' ')}"
    when :debian then "apt-get remove -y --purge #{pkgs.join(' ')}"
    else              "dnf remove -y #{pkgs.join(' ')}"
    end
  end

  def pkg_autoremove_cmd
    case @family
    when :macos  then 'brew autoremove'
    when :debian then 'apt-get autoremove -y --purge'
    else              'dnf autoremove -y'
    end
  end

  def pkg_installed?(pkg)
    case @family
    when :macos  then Runner.installed_pkg_brew?(pkg)
    when :debian then Runner.installed_pkg_debian?(pkg)
    else              Runner.installed_pkg_rhel?(pkg)
    end
  end

  def arch
    @arch ||= `uname -m`.strip
  end

  # Normalised arch token used for binary download URLs.
  # Returns 'arm64' or 'amd64' on all platforms.
  def dl_arch
    case arch
    when 'aarch64', 'arm64' then 'arm64'
    else                         'amd64'
    end
  end

  def epel_needed? = rhel?

  private

  def detect
    # macOS — check before /etc/os-release (which doesn't exist on Darwin)
    if RUBY_PLATFORM.include?('darwin')
      version = `sw_vers -productVersion 2>/dev/null`.strip
      return [:macos, :macos, version]
    end

    return [:unknown, :unknown, ''] unless File.exist?('/etc/os-release')

    info = File.read('/etc/os-release').scan(/^(\w+)=(.+)$/).to_h do |k, v|
      [k.downcase, v.delete('"\'')]
    end

    id      = (info['id'] || 'unknown').downcase
    like    = (info['id_like'] || '').downcase
    version = info['version_id'] || ''

    family = if %w[ubuntu debian].include?(id) || like.include?('debian')
               :debian
             elsif %w[rhel centos fedora rocky almalinux].include?(id) || like.match?(/rhel|centos|fedora/)
               :rhel
             else
               :unknown
             end

    [id, family, version]
  end
end

