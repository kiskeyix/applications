#!/bin/bash
# Delete a branch both local and in the remote repo
#
# If the branch is not merged to HEAD, it stops you.
#
# Usage: gitbranchdelete BRANCH_NAME
#
# Luis Mondesi <lemsx1@gmail.com>
# License: GPL

# We remove the branch from a remote repository
_git_remote_delete()
{
    git push origin --delete $1
    git remote prune origin
}

# A branch that was squash-merged has no commit that is an ancestor of the
# base branch, so `git branch --merged` never sees it as merged. Detect this
# by reverse-applying the branch's diff (against its merge-base) onto the
# base branch: if it applies cleanly, the branch's changes are already there.
_is_squash_merged()
{
    local _mb
    _mb=$(git merge-base "$2" "$1" 2> /dev/null)
    if [[ -z "$_mb" ]]; then
        return 1
    fi
    git diff "$_mb" "$1" | git apply --check --reverse > /dev/null 2>&1
}

# only remove local branch if not merged to HEAD
_git_local_delete()
{
    _merged=0
    _squash=0
    #git branch --no-color --merged | awk '{print $NF}'
    for branch in $(git for-each-ref --color=never --format='%(refname:lstrip=2)' refs/heads --merged); do
        if [[ $branch == $1 ]]; then
            _merged=1
            break
        fi
    done
    if [[ $_merged == 0 ]] && _is_squash_merged "$1" "$2"; then
        _merged=1
        _squash=1
    fi
    if [[ $_merged == 1 ]]; then
        if [[ $_squash == 1 ]]; then
            printf "  INFO: '%s' appears to be squash-merged into '%s'; force-deleting\n" "$1" "$2"
            git branch -D $1
        else
            git branch -d $1
        fi
    else
        printf "  ERROR: cannot delete local branch '$1'. It is not merged to HEAD\n"
        printf "\t delete by hand with: git branch -d '$1'\n"
        exit 1
    fi
}

if [[ -x `command -v git` ]]; then
    _base_branch=""
    if git checkout main 2> /dev/null; then
        _base_branch=main
    elif git checkout master; then
        _base_branch=master
    fi
    if [[ -n "$_base_branch" ]]; then
        _local_found=0
        for branch in $(git for-each-ref --color=never --format='%(refname:lstrip=2)' refs/heads); do
            if [[ $branch == $1 ]]; then
                _local_found=1
                break
            fi
        done
        if [[ $_local_found == 1 ]]; then
            _git_local_delete $1 $_base_branch
            _git_remote_delete $1
        else
            _git_remote_delete $1
        fi
    else
        echo "No 'main' (or 'master') branch" >> /dev/stderr
        exit 1
    fi
else
    echo "Git command missing" >> /dev/stderr
    exit 1
fi
